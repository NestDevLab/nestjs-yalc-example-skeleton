{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.ts$": [
      "ts-jest",
      {
        "tsconfig": "<rootDir>/../../../tsconfig.e2e.json",
        "diagnostics": false,
        "astTransformers": {
          "before": ["<rootDir>/graphql-plugin.wrapper.cjs"]
        }
      }
    ]
  },
  "moduleNameMapper": {
    "^p-map$": "<rootDir>/p-map.mock.ts",
    "^@nestjs-yalc/skeleton-module$": "<rootDir>/../../../../module/src",
    "^@nestjs-yalc/skeleton-module/src/(.*)$": "<rootDir>/../../../../module/src/$1",
    "^@nestjs/(.*)$": "<rootDir>/../../../../../../node_modules/@nestjs/$1",
    "^typeorm$": "<rootDir>/../../../../../../node_modules/typeorm",
    "^@nestjs-yalc/([^/]+)/(.+?)\\.js$": "<rootDir>/../../../../../../$1/src/$2",
    "^@nestjs-yalc/([^/]+)/(.*)$": "<rootDir>/../../../../../../$1/src/$2",
    "^@nestjs-yalc/([^/]+)$": "<rootDir>/../../../../../../$1/src",
    "^@skeleton-app/skeleton-base-app(|/.*)$": "<rootDir>/../../../libs/skeleton-base-app/src/$1",
    "^lodash-es$": "lodash",
    "^(\\.{1,2}/.*)\\.js$": "$1"
  }
}

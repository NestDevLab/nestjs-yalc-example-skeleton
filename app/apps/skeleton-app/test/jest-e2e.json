{
  "moduleFileExtensions": [
    "js",
    "json",
    "ts"
  ],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.ts$": [
      "ts-jest",
      {
        "tsconfig": "<rootDir>/../../../tsconfig.e2e.json",
        "diagnostics": false,
        "astTransformers": {
          "before": [
            "<rootDir>/graphql-plugin.wrapper.cjs"
          ]
        },
        "useESM": true
      }
    ]
  },
  "moduleNameMapper": {
    "^p-map$": "<rootDir>/p-map.mock.ts",
    "^@nestjs-yalc/skeleton-module$": "<rootDir>/../../../../module/src",
    "^@nestjs-yalc/skeleton-module/src/(.*)$": "<rootDir>/../../../../module/src/$1",
    "^@skeleton-app/skeleton-base-app(|/.*)$": "<rootDir>/../../../libs/skeleton-base-app/src/$1",
    "^@nestjs/(.*)$": "<rootDir>/../../../../node_modules/@nestjs/$1",
    "^typeorm$": "<rootDir>/../../../../node_modules/typeorm",
    "^@nestjs-yalc/([^/]+)/(.+?)\\.js$": "<rootDir>/../../../../node_modules/@nestjs-yalc/$1/src/$2",
    "^@nestjs-yalc/([^/]+)/(.*)$": "<rootDir>/../../../../node_modules/@nestjs-yalc/$1/src/$2",
    "^@nestjs-yalc/([^/]+)$": "<rootDir>/../../../../node_modules/@nestjs-yalc/$1/src",
    "^(\\.{1,2}/.*)\\.js$": "$1"
  },
  "extensionsToTreatAsEsm": [
    ".ts"
  ]
}
